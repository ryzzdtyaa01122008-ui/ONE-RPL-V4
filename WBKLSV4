gaya.* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Poppins', sans-serif;
  scroll-behavior: smooth;
}

body {
  background: linear-gradient(135deg, #0f172a, #1e293b);
  color: #f8fafc;
  line-height: 1.6;
}

.navbar {
  background: rgba(15, 23, 42, 0.9);
  padding: 15px 5%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 99;
  border-bottom: 2px solid #38bdf8;
}
.logo { font-size: 20px; font-weight: 700; color: #38bdf8; }
.nav-links { display: flex; list-style: none; gap: 20px; }
.nav-links a { color: #f8fafc; text-decoration: none; font-weight: 500; transition: 0.3s; }
.nav-links a:hover { color: #38bdf8; }

.beranda {
  padding: 120px 5%;
  text-align: center;
  background: linear-gradient(rgba(15,23,42,0.8), rgba(15,23,42,0.8));
}
.beranda h1 { font-size: 36px; margin-bottom: 15px; color: #38bdf8; }
.beranda p { font-size: 18px; margin-bottom: 30px; }
.tombol {
  display: inline-block;
  padding: 12px 30px;
  background: #38bdf8;
  color: #0f172a;
  font-weight: 600;
  border-radius: 50px;
  text-decoration: none;
  transition: 0.3s;
}
.tombol:hover { background: #0ea5e9; transform: translateY(-3px); }

section { padding: 60px 5%; max-width: 1200px; margin: auto; }
section h2 { text-align: center; margin-bottom: 40px; color: #38bdf8; font-size: 28px; }

.kotak-profil {
  background: rgba(30, 41, 59, 0.8);
  padding: 25px;
  border-radius: 12px;
  border-left: 4px solid #38bdf8;
}
.kotak-profil p { margin: 10px 0; font-size: 16px; }

.daftar-siswa {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 12px;
}
.daftar-siswa span {
  background: rgba(30, 41, 59, 0.8);
  padding: 10px;
  text-align: center;
  border-radius: 8px;
  border: 1px solid #38bdf8;
  transition: 0.3s;
}
.daftar-siswa span:hover { background: #38bdf8; color: #0f172a; }

.tabel-jadwal {
  width: 100%;
  border-collapse: collapse;
  background: rgba(30, 41, 59, 0.8);
  border-radius: 12px;
  overflow: hidden;
}
.tabel-jadwal th, .tabel-jadwal td {
  padding: 12px;
  text-align: center;
  border-bottom: 1px solid #38bdf8;
}
.tabel-jadwal th { background: #38bdf8; color: #0f172a; font-weight: 600; }

.moto { text-align: center; }
.kalimat-moto {
  font-size: 22px;
  font-style: italic;
  color: #93c5fd;
  padding: 20px;
  border: 2px solid #38bdf8;
  border-radius: 12px;
  display: inline-block;
}

footer {
  text-align: center;
  padding: 25px;
  background: rgba(15, 23, 42, 0.9);
  border-top: 2px solid #38bdf8;
  font-size: 14px;
}

@media(max-width: 768px){
  .nav-links { gap: 12px; font-size: 14px; }
  .beranda h1 { font-size: 28px; }
  .tabel-jadwal { font-size: 13px; }
}

kode.document.querySelectorAll('.nav-links a').forEach(link => {
  link.addEventListener('click', function(e){
    e.preventDefault();
    const tujuan = document.querySelector(this.getAttribute('href'));
    tujuan.scrollIntoView({behavior: 'smooth', block: 'start'});
  });
});

const semuaBagian = document.querySelectorAll('section');
const pengamat = new IntersectionObserver((masuk) => {
  masuk.forEach(item => {
    if(item.isIntersecting){
      item.target.style.opacity = 1;
      item.target.style.transform = 'translateY(0)';
    }
  });
}, {threshold: 0.1});

semuaBagian.forEach(bagian => {
  bagian.style.opacity = 0;
  bagian.style.transform = 'translateY(20px)';
  bagian.style.transition = 'all 0.6s ease';
  pengamat.observe(bagian);
});
